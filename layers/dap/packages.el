;;
;; Compatibility layer for dotfile declarations like:
;;   dap
;;
;; NOTE:
;; Many language layers already manage `dap-mode`. To keep upgrades stable and
;; avoid "More than one init function" warnings, this layer is intentionally
;; empty and only satisfies the layer declaration.

(defconst dap-packages
  '()
  "Compatibility layer: no packages declared.")

